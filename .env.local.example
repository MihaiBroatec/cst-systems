# ============================================================
# SMTP — setări pentru trimiterea emailurilor
# Copiaza acest fisier in .env.local si completeaza valorile
# ============================================================

# Adresa serverului SMTP (ex: mail.cst-systems.ro sau smtp.gmail.com)
SMTP_HOST=mail.cst-systems.ro

# Portul SMTP: 465 (SSL) sau 587 (STARTTLS) sau 25
SMTP_PORT=465

# true daca folosesti SSL (port 465), false pentru STARTTLS (port 587)
SMTP_SECURE=true

# Emailul de autentificare (de obicei acelasi cu adresa de expeditor)
SMTP_USER=hello@cst-systems.ro

# Parola emailului
SMTP_PASS=parola_ta_smtp
